{
  "name": "dither",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "preview": "bun run build && bun run --cwd apps/web preview",
    "lint": "turbo lint",
    "test": "turbo test",
    "format": "turbo format",
    "format:check": "turbo format:check",
    "typecheck": "turbo typecheck",
    "verify": "bun run format:check && bun run lint && bun run typecheck && bun run test && bun run build",
    "prepare": "husky",
    "lint-staged": "lint-staged"
  },
  "devDependencies": {
    "babel-plugin-react-compiler": "^1.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.17",
    "typescript": "5.9.3",
    "vitest": "^4.1.5"
  },
  "packageManager": "bun@1.3.13",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
