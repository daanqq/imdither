{
  "name": "dither",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "preview": "bun run build && bun run --cwd apps/web preview",
    "lint": "oxlint apps packages",
    "test": "turbo test",
    "format": "oxfmt apps packages --write",
    "format:check": "oxfmt apps packages --check",
    "typecheck": "turbo typecheck",
    "check": "bun run verify:static",
    "verify:static": "concurrently --kill-others-on-fail -n format,lint,typecheck,test \"bun run format:check\" \"bun run lint\" \"bun run typecheck\" \"bun run test\"",
    "verify": "bun run verify:static && bun run build",
    "prepare": "husky",
    "lint-staged": "lint-staged"
  },
  "devDependencies": {
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "turbo": "^2.8.17",
    "typescript": "5.9.3",
    "vitest": "^4.1.5"
  },
  "packageManager": "bun@1.3.13",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "gifenc": "^1.0.3",
    "gifuct-js": "^2.1.2"
  }
}
